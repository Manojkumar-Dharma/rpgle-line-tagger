{
  "name": "itagger",
  "displayName": "iTagger",
  "description": "Add a source modification tag to selected lines in RPGLE, CLP/CLLE, and SQL source files at a fixed column, using the right comment style for each (//, /* */, --).",
  "version": "0.0.8",
  "publisher": "Manojkumar-IBMi",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Manojkumar-Dharma/rpgle-line-tagger.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "itagger.addTag",
        "title": "iTagger: Add Source Tag"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "itagger.addTag",
          "group": "9_cutcopypaste"
        }
      ]
    },
    "configuration": {
      "title": "iTagger",
      "properties": {
        "itagger.maxLineLength": {
          "type": "number",
          "default": 100,
          "description": "Total usable line length for source lines."
        },
        "itagger.tagColumn": {
          "type": "number",
          "default": 90,
          "description": "1-indexed column where the tag should start when there's room."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
